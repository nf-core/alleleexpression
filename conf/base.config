/*
========================================================================================
    Base config file for all processes
========================================================================================
    Contains default config options for all environments and processing profiles
*/

process {
    cpus   = { [1 * task.attempt, params.max_cpus as int].min() }
    memory = { [6.GB * task.attempt, params.max_memory as nextflow.util.MemoryUnit].min() }
    time   = { [4.h * task.attempt, params.max_time as nextflow.util.Duration].min() }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // Process-specific resource requirements
    withLabel:process_low {
        cpus   = { [2 * task.attempt, params.max_cpus as int].min() }
        memory = { [4.GB * task.attempt, params.max_memory as nextflow.util.MemoryUnit].min() }
        time   = { [4.h * task.attempt, params.max_time as nextflow.util.Duration].min() }
    }
    withLabel:process_medium {
        cpus   = { [6 * task.attempt, params.max_cpus as int].min() }
        memory = { [8.GB * task.attempt, params.max_memory as nextflow.util.MemoryUnit].min() }
        time   = { [8.h * task.attempt, params.max_time as nextflow.util.Duration].min() }
    }
    withLabel:process_high {
        cpus   = { [10 * task.attempt, params.max_cpus as int].min() }
        memory = { [24.GB * task.attempt, params.max_memory as nextflow.util.MemoryUnit].min() }
        time   = { [16.h * task.attempt, params.max_time as nextflow.util.Duration].min() }
    }
    withLabel:process_long {
        time   = { [20.h * task.attempt, params.max_time as nextflow.util.Duration].min() }
    }
    withLabel:process_high_memory {
        memory = { [28.GB * task.attempt, params.max_memory as nextflow.util.MemoryUnit].min() }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
